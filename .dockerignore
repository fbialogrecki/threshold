# Backend builds use the repository root as context. Deny everything first and
# explicitly admit only immutable dependency metadata and backend build inputs.
**
!.dockerignore
!pyproject.toml
!uv.lock

!libs/
!libs/py/
!libs/py/pyproject.toml
!libs/py/threshold_common/
!libs/py/threshold_common/**

!services/
!services/auth-gateway/
!services/auth-gateway/Dockerfile
!services/auth-gateway/pyproject.toml
!services/auth-gateway/alembic.ini
!services/auth-gateway/src/
!services/auth-gateway/src/**

!services/events/
!services/events/Dockerfile
!services/events/pyproject.toml
!services/events/alembic.ini
!services/events/src/
!services/events/src/**
!services/events/migrations/
!services/events/migrations/**

!services/media/
!services/media/Dockerfile
!services/media/pyproject.toml
!services/media/alembic.ini
!services/media/src/
!services/media/src/**
!services/media/migrations/
!services/media/migrations/**

!services/social/
!services/social/Dockerfile
!services/social/pyproject.toml
!services/social/alembic.ini
!services/social/src/
!services/social/src/**
!services/social/migrations/
!services/social/migrations/**

!services/users/
!services/users/Dockerfile
!services/users/pyproject.toml
!services/users/alembic.ini
!services/users/src/
!services/users/src/**
!services/users/migrations/
!services/users/migrations/**
