# Threshold web — local dev environment (names + dummy values only, no secrets).
# Copy to .env.local for `task web:dev` / `bun --bun next dev`.

# Server-only base URLs used by the BFF. Adjust ports to match your local service setup.
USERS_SERVICE_URL=http://127.0.0.1:8001
EVENTS_SERVICE_URL=http://127.0.0.1:8002
SOCIAL_SERVICE_URL=http://127.0.0.1:8003
MEDIA_SERVICE_URL=http://127.0.0.1:8004
THRESHOLD_INTERNAL_TOKEN=

# Public production must use Secure cookies. A production instance intentionally
# limited to trusted plain-HTTP LAN access may instead set
# WEB_TRUSTED_LAN_HTTP=true; never expose that mode publicly.
AUTH_COOKIE_SECURE=false
WEB_TRUSTED_LAN_HTTP=false
